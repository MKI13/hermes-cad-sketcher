{
  "name": "hermes-cad-sketcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SketchUp-like lightweight CAD sketcher for Linux: draw lines/rectangles/boxes, move faces, components, orbit view, measure, import/export.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "agent:bridge": "python3 scripts/hermes-cad-agent-bridge.py",
    "smoke:browser": "node scripts/smoke-browser.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "three": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/three": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
